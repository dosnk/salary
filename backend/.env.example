# 数据库配置
DB_USER=salary
DB_HOST=localhost
DB_NAME=salary
DB_PASSWORD=your_database_password_here
DB_PORT=5432

# JWT密钥（生产环境请使用强随机字符串）
JWT_SECRET=your_jwt_secret_here

# 服务器配置
PORT=3000
NODE_ENV=development

# 日志目录配置（生产环境必须设置）
# 说明: 指定日志文件的存储路径
# Windows示例: C:\salary-logs 或 ./logs
# Linux示例: /var/log/salary 或 ./logs
# 相对路径示例: ./logs (相对于backend目录)
# 生产环境建议使用绝对路径，例如: /var/log/salary 或 C:\salary-logs
LOG_DIR=./logs

# 服务器地址配置（部署时修改）
# 说明: 用于Swagger文档和API访问地址
# 开发环境: http://localhost:3000/v1
# 生产环境: 修改为实际域名或IP地址，例如:
#   - http://your-domain.com/v1
#   - http://192.168.1.100/v1
#   - https://api.your-domain.com/v1
# 注意: URL必须包含/v1路径前缀
SERVER_URL=http://localhost:3000/v1

# 部署示例:
# 1. 本地开发: SERVER_URL=http://localhost:3000/v1
# 2. 局域网IP: SERVER_URL=http://192.168.1.100:3000/v1
# 3. 域名部署: SERVER_URL=http://api.example.com/v1
# 4. HTTPS部署: SERVER_URL=https://api.example.com/v1

# ==================== AI模块配置 ====================

# AI提供商选择（默认: deepseek）
# 可选值: tongyi(通义千问) | wenxin(文心一言) | deepseek(DeepSeek) | glm(智谱ChatGLM) | doubao(豆包)
AI_PROVIDER=deepseek

# 通义千问（阿里云）- https://dashscope.aliyuncce.com/
TONGYI_API_KEY=
TONGYI_MODEL=qwen-plus

# 文心一言（百度）- https://console.bce.baidu.com/
WENXIN_API_KEY=
WENXIN_SECRET_KEY=
WENXIN_MODEL=ernie-4.0-8k

# DeepSeek - https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# 智谱ChatGLM - https://open.bigmodel.cn/
GLM_API_KEY=
GLM_MODEL=glm-4

# 豆包（字节跳动）- https://www.volcengine.com/
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-pro-4k
