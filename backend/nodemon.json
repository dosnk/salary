{
  "watch": [
    "index.js",
    "controllers/",
    "services/",
    "repositories/",
    "routes/",
    "middleware/",
    "config/",
    "ai/",
    "jobs/",
    "strategies/",
    "utils/"
  ],
  "ext": "js json",
  "ignore": [
    "node_modules/",
    "logs/",
    "temp/",
    "tests/",
    "*.test.js",
    "*.spec.js"
  ],
  "delay": 1000,
  "verbose": true,
  "env": {
    "NODE_ENV": "development"
  }
}
