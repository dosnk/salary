# 测试环境配置
# 使用独立的测试数据库，避免污染开发/生产数据

# 测试数据库（与开发库分离）
DB_USER=postgres
DB_HOST=localhost
DB_NAME=salary_test
DB_PASSWORD=
DB_PORT=5432

# JWT测试密钥
JWT_SECRET=test-jwt-secret-for-integration-tests
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 服务器配置
PORT=3001
NODE_ENV=test

# Redis测试配置（使用DB 1，避免与开发数据冲突）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# 日志静默
LOG_LEVEL=error
LOG_DIR=./logs

# 服务器地址
SERVER_URL=http://localhost:3001/v1
